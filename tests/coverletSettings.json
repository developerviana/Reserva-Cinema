{
  "version": 1,
  "title": "ReservaCinema Code Coverage",
  "description": "Configuração de cobertura de código para testes",
  "sourceLanguage": "csharp",
  "exclude": [
    "**/Program.cs",
    "**/Startup.cs",
    "**/*.csproj",
    "**/*.Tests/**",
    "**/Migrations/**"
  ],
  "include": [
    "**/ReservaCinema.Domain/**",
    "**/ReservaCinema.Application/**",
    "**/ReservaCinema.API/**",
    "**/ReservaCinema.Infrastructure/**"
  ],
  "reportFormats": [
    "opencover",
    "lcov",
    "html"
  ]
}
